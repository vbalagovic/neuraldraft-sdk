{
  "name": "@neuraldraft/sdk",
  "version": "0.3.0",
  "description": "Official TypeScript SDK for the Neural Draft Project API — typed helpers for brand, content, blog, images, products, booking, and async jobs.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "keywords": [
    "neuraldraft",
    "neural-draft",
    "sdk",
    "cms",
    "blog",
    "commerce",
    "booking",
    "content",
    "i18n",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vbalagovic/neuraldraft-sdk.git"
  },
  "homepage": "https://docs.neuraldraft.io",
  "bugs": {
    "url": "https://github.com/vbalagovic/neuraldraft-sdk/issues"
  },
  "author": "Neural Draft <developers@neuraldraft.io>",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "nock": "^14.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.4.0"
  }
}
